# Kite Mainnet RPC (required for indexing chain 2366)
PONDER_RPC_URL_2366=https://rpc.gokite.ai

# Postgres connection string. Examples:
#   Supabase pooler: postgresql://postgres:[PWD]@db.[REF].supabase.co:6543/postgres?sslmode=require
#   Self-hosted:     postgres://kiteindex:kiteindex@localhost:5432/kiteindex
# When unset in dev, Ponder uses PGlite (embedded) — fine for local poking but loses data on restart.
DATABASE_URL=

# Optional: starting block. Use a recent block to avoid waiting hours for backfill.
PONDER_START_BLOCK=89000
